@{
    Layout = null;
}

<div class="dashboard-header mb-4">
    <h2><i class="fa fa-dashboard"></i> Dashboard</h2>
    <p class="text-muted">Welcome to the Mantle CMS administration area.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-6">
        <a href="#membership" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-primary text-white rounded-circle me-3">
                        <i class="fa fa-users"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Membership</h6>
                        <small class="text-muted">Manage users &amp; roles</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#pages" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-success text-white rounded-circle me-3">
                        <i class="fa fa-file-text-o"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Pages</h6>
                        <small class="text-muted">Content pages</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#blog" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-info text-white rounded-circle me-3">
                        <i class="fa fa-pencil-square-o"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Blog</h6>
                        <small class="text-muted">Posts &amp; categories</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#media" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-warning text-white rounded-circle me-3">
                        <i class="fa fa-picture-o"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Media</h6>
                        <small class="text-muted">Files &amp; uploads</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-6">
        <a href="#menus" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-secondary text-white rounded-circle me-3">
                        <i class="fa fa-bars"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Menus</h6>
                        <small class="text-muted">Navigation menus</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#content-blocks" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-dark text-white rounded-circle me-3">
                        <i class="fa fa-th-large"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Content Blocks</h6>
                        <small class="text-muted">Reusable content</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#configuration/settings" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-danger text-white rounded-circle me-3">
                        <i class="fa fa-cog"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Settings</h6>
                        <small class="text-muted">Site configuration</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-lg-3 col-md-6">
        <a href="#scheduled-tasks" class="text-decoration-none">
            <div class="card dashboard-card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="dashboard-card-icon bg-primary text-white rounded-circle me-3">
                        <i class="fa fa-clock-o"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0">Scheduled Tasks</h6>
                        <small class="text-muted">Background jobs</small>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="fa fa-wrench me-2"></i>Maintenance</h6>
            </div>
            <div class="list-group list-group-flush">
                <a href="#log" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="fa fa-warning text-warning me-2"></i> View Log
                </a>
                <a href="#localization/languages" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="fa fa-globe text-info me-2"></i> Languages
                </a>
                <a href="#plugins" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="fa fa-puzzle-piece text-secondary me-2"></i> Plugins
                </a>
                <a href="#configuration/themes" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="fa fa-tint text-primary me-2"></i> Themes
                </a>
            </div>
        </div>
    </div>
    <div class="col-lg-8 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="fa fa-info-circle me-2"></i>About Mantle CMS</h6>
            </div>
            <div class="card-body">
                <p>Mantle is a multi-purpose framework and CMS for creating any type of website. It includes a plugin system, theme engine, file manager, membership management, localization, blog, menus, scheduled tasks, and more.</p>
                <div class="row text-center mt-3">
                    <div class="col-4">
                        <div class="border rounded p-3">
                            <i class="fa fa-plug fa-2x text-muted mb-2"></i>
                            <div><strong>Extensible</strong></div>
                            <small class="text-muted">Plugin architecture</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="border rounded p-3">
                            <i class="fa fa-building-o fa-2x text-muted mb-2"></i>
                            <div><strong>Multi-tenant</strong></div>
                            <small class="text-muted">Multiple sites</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="border rounded p-3">
                            <i class="fa fa-paint-brush fa-2x text-muted mb-2"></i>
                            <div><strong>Themeable</strong></div>
                            <small class="text-muted">Theme engine</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>